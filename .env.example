# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# ── LLM API ──────────────────────────────────────────────────────────────────
OPENAI_API_BASE_URL=https://your-llm-endpoint/v1
OPENAI_API_KEY=your-api-key
MODEL_NAME=your-model-name

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_POOL_SIZE=50
DATABASE_POOL_MAX_OVERFLOW=5

# ── Vector DB ─────────────────────────────────────────────────────────────────
# Supported: qdrant | chroma | milvus | elasticsearch | opensearch | pgvector
VECTOR_DB=qdrant
QDRANT_URI=http://your-qdrant-host:6333

# ── RAG / Embeddings ──────────────────────────────────────────────────────────
# Supported engines: gemini | openai | ollama | azure_openai (leave empty for local)
RAG_EMBEDDING_ENGINE=gemini
RAG_EMBEDDING_MODEL=models/gemini-embedding-001
RAG_TOP_K=10
ENABLE_RAG_HYBRID_SEARCH=true
RAG_EMBEDDING_OPENAI_BATCH_SIZE=5
RAG_EMBEDDING_BATCH_SIZE=16
CHUNK_SIZE=10000
CHUNK_OVERLAP=200
TOKENIZERS_PARALLELISM=true

# ── Optional integrations ─────────────────────────────────────────────────────
LLAMA_CLOUD_API_KEY=

# LangSmith tracing (set LANGSMITH_TRACING=false to disable)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=open-webui

# ── Ollama (if using local models) ────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── CORS / network ───────────────────────────────────────────────────────────
CORS_ALLOW_ORIGIN=*
FORWARDED_ALLOW_IPS=*

# ── Telemetry (off by default) ────────────────────────────────────────────────
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
